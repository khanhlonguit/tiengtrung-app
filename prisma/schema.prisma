// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lesson {
  id         Int          @id
  title_vn   String
  title_zh   String
  subtitle   String
  vocabulary Vocabulary[]
  grammar    Grammar[]
  dialogues  Dialogue[]
  exercises  Exercise[]
}

model Vocabulary {
  id             Int    @id @default(autoincrement())
  lesson_id      Int
  order_num      Int
  word_zh        String
  pinyin         String
  word_type      String @default("")
  meaning_vn     String
  meaning_en     String @default("")
  meaning_hv     String @default("")
  example_zh     String @default("")
  example_pinyin String @default("")
  example_vn     String @default("")
  example_en     String @default("")
  lesson         Lesson @relation(fields: [lesson_id], references: [id])
}

model Grammar {
  id          Int    @id @default(autoincrement())
  lesson_id   Int
  order_num   Int
  title       String
  explanation String
  examples    String @default("[]")
  lesson      Lesson @relation(fields: [lesson_id], references: [id])
}

model Dialogue {
  id             Int    @id @default(autoincrement())
  lesson_id      Int
  dialogue_num   Int
  line_order     Int
  speaker        String
  text_zh        String
  pinyin         String
  translation_vn String
  lesson         Lesson @relation(fields: [lesson_id], references: [id])
}

model Exercise {
  id        Int                @id @default(autoincrement())
  lesson_id Int
  title     String
  lesson    Lesson             @relation(fields: [lesson_id], references: [id])
  questions ExerciseQuestion[]
}

model ExerciseQuestion {
  id          Int      @id @default(autoincrement())
  exercise_id Int
  question    String
  answer      String
  hint        String   @default("")
  exercise    Exercise @relation(fields: [exercise_id], references: [id])
}
